# ─────────────────────────────────────────────
# CareerPilot — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
APP_NAME=CareerPilot
APP_URL=http://localhost:5000

# ── Database ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=careerpilot
POSTGRES_USER=careerpilot_user
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://careerpilot_user:changeme_in_production@localhost:5432/careerpilot

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_production

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=generate_64_char_random_string_here
JWT_REFRESH_SECRET=generate_another_64_char_random_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=60d

# ── Session ──────────────────────────────────
SESSION_SECRET=generate_64_char_random_string_here
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── OAuth — Google ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── OAuth — LinkedIn ─────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/v1/auth/linkedin/callback

# ── OAuth — GitHub ───────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# ── AI — Primary (Claude) ────────────────────
ANTHROPIC_API_KEY=

# ── AI — Fallback (Gemini) ───────────────────
GEMINI_API_KEY=

# ── JSearch API (RapidAPI) ───────────────────
JSEARCH_API_KEY=
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com

# ── Email (Nodemailer + Gmail SMTP) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=CareerPilot <noreply@careerpilot.dev>

# ── Cloudflare R2 (CV Storage) ───────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=careerpilot-cvs
R2_PUBLIC_URL=

# ── Web Push Notifications ───────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@careerpilot.dev

# ── Google Calendar ──────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── pgAdmin (dev only) ───────────────────────
PGADMIN_EMAIL=admin@careerpilot.dev
PGADMIN_PASSWORD=admin123

# ── Cache Durations (milliseconds) ───────────
CACHE_JOB_LISTINGS_MS=43200000
CACHE_CV_ATS_MS=86400000
CACHE_MARKET_TREND_MS=604800000
CACHE_INTERVIEW_QUESTIONS_MS=2592000000
CACHE_DAILY_ACTION_PLAN_MS=86400000
CACHE_LEARNING_ROADMAP_MS=604800000
CACHE_SALARY_INSIGHTS_MS=604800000
CACHE_COVER_LETTER_MS=604800000
CACHE_PRO_TIPS_MS=604800000
CACHE_SEARCH_RESULTS_MS=300000

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ── BullMQ ───────────────────────────────────
QUEUE_MAX_CONCURRENCY=5

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ── Maintenance Mode ─────────────────────────
MAINTENANCE_MODE=false